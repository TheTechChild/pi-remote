{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheTechChild/pi-remote-spec/protocol/coordinator-app/machine_state_change.json",
  "title": "machine_state_change",
  "description": "Coordinator -> App. Single-machine state delta. See SPEC.md § 10.3.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "v", "machine_id", "state"],
  "properties": {
    "type": { "const": "machine_state_change" },
    "v": { "const": 1 },
    "machine_id": { "type": "string" },
    "state": {
      "type": "string",
      "enum": ["online", "suspended", "offline"]
    }
  }
}
