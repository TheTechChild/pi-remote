{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheTechChild/pi-remote-spec/protocol/coordinator-app/session_event.json",
  "title": "session_event",
  "description": "Coordinator -> App. Forwarded session_event sent only to clients attached to the session. See SPEC.md § 10.3.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "v", "session_id", "seq", "kind", "ts", "data"],
  "properties": {
    "type": { "const": "session_event" },
    "v": { "const": 1 },
    "session_id": { "type": "string" },
    "seq": { "type": "integer", "minimum": 1 },
    "kind": {
      "type": "string",
      "enum": [
        "agent_start",
        "agent_end",
        "attention_dialog",
        "tool_failure",
        "queue_update",
        "model_select",
        "compaction_start",
        "compaction_end",
        "extension_error"
      ]
    },
    "ts": { "type": "integer", "minimum": 0 },
    "data": { "type": "object" }
  }
}
