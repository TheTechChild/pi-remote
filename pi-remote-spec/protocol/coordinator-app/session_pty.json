{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheTechChild/pi-remote-spec/protocol/coordinator-app/session_pty.json",
  "title": "session_pty",
  "description": "Coordinator -> App. Forwarded session_pty sent only to attached clients. See SPEC.md § 10.3.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "v", "session_id", "seq", "ts", "bytes"],
  "properties": {
    "type": { "const": "session_pty" },
    "v": { "const": 1 },
    "session_id": { "type": "string" },
    "seq": { "type": "integer", "minimum": 1 },
    "ts": { "type": "integer", "minimum": 0 },
    "bytes": { "type": "string", "contentEncoding": "base64" },
    "compression": {
      "type": ["string", "null"],
      "enum": [null, "none", "zstd"]
    }
  }
}
