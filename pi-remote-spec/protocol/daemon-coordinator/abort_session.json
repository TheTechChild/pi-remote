{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheTechChild/pi-remote-spec/protocol/daemon-coordinator/abort_session.json",
  "title": "abort_session",
  "description": "Coordinator -> Daemon. Terminate a Pi session. See SPEC.md § 10.2.",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "v", "session_id", "mode"],
  "properties": {
    "type": { "const": "abort_session" },
    "v": { "const": 1 },
    "session_id": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["kill"]
    }
  }
}
