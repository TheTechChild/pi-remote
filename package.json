{
  "name": "@thetechchild/pi-remote",
  "version": "1.0.0",
  "type": "module",
  "description": "Pi Remote — session-sharing for the Pi coding agent. This package.json declares the pi extension and orchestrates the TypeScript half of the monorepo. The daemon, coordinator, and Android app live in their own subdirectories with their own toolchains.",
  "license": "MIT",
  "author": "Clayton",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheTechChild/pi-remote.git"
  },
  "keywords": ["pi-package"],
  "scripts": {
    "build": "tsc -p pi-remote-ext",
    "typecheck": "tsc -p pi-remote-ext --noEmit",
    "lint": "biome check --config-path=pi-remote-ext pi-remote-ext",
    "format": "biome format --write --config-path=pi-remote-ext pi-remote-ext",
    "test": "vitest run --root pi-remote-ext",
    "test:watch": "vitest --root pi-remote-ext",
    "codegen": "bash pi-remote-ext/scripts/codegen.sh"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.73.1",
    "@sinclair/typebox": "^0.34.0",
    "ajv": "^8.17.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "json-schema-to-typescript": "^15.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "pi": {
    "extensions": ["./pi-remote-ext/src/index.ts"]
  }
}
